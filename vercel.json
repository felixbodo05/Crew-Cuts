{
    "cleanUrls": true,
    "rewrites": [
        {
            "source": "/",
            "destination": "/src/index.html"
        },
        {
            "source": "/booking",
            "destination": "/src/booking.html"
        },
        {
            "source": "/login",
            "destination": "/src/login.html"
        },
        {
            "source": "/profile",
            "destination": "/src/profile.html"
        },
        {
            "source": "/admin",
            "destination": "/src/admin.html"
        },
        {
            "source": "/barbers",
            "destination": "/src/barbers.html"
        },
        {
            "source": "/contact",
            "destination": "/src/contact.html"
        },
        {
            "source": "/portfolio",
            "destination": "/src/portfolio.html"
        },
        {
            "source": "/css/(.*)",
            "destination": "/src/css/$1"
        },
        {
            "source": "/js/(.*)",
            "destination": "/src/js/$1"
        },
        {
            "source": "/images/(.*)",
            "destination": "/src/images/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/src/$1.html"
        }
    ]
}