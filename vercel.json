{
    "version": 2,
    "cleanUrls": true,
    "builds": [
        {
            "src": "src/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/",
            "dest": "/src/index.html"
        },
        {
            "src": "/booking",
            "dest": "/src/booking.html"
        },
        {
            "src": "/login",
            "dest": "/src/login.html"
        },
        {
            "src": "/profile",
            "dest": "/src/profile.html"
        },
        {
            "src": "/admin",
            "dest": "/src/admin.html"
        },
        {
            "src": "/barbers",
            "dest": "/src/barbers.html"
        },
        {
            "src": "/contact",
            "dest": "/src/contact.html"
        },
        {
            "src": "/portfolio",
            "dest": "/src/portfolio.html"
        },
        {
            "src": "/(.*)",
            "dest": "/src/$1"
        }
    ]
}