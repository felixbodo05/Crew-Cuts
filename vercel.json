{
    "version": 2,
    "cleanUrls": true,
    "builds": [
        {
            "src": "src/**",
            "use": "@vercel/static"
        }
    ],
    "rewrites": [
        {
            "source": "/",
            "destination": "/src/index.html"
        },
        {
            "source": "/booking",
            "destination": "/src/booking.html"
        },
        {
            "source": "/login",
            "destination": "/src/login.html"
        },
        {
            "source": "/profile",
            "destination": "/src/profile.html"
        },
        {
            "source": "/admin",
            "destination": "/src/admin.html"
        },
        {
            "source": "/barbers",
            "destination": "/src/barbers.html"
        },
        {
            "source": "/contact",
            "destination": "/src/contact.html"
        },
        {
            "source": "/portfolio",
            "destination": "/src/portfolio.html"
        },
        {
            "source": "/(.*)",
            "destination": "/src/$1"
        }
    ]
}